":[""]}],"actions":[{"type":{"value":"ResetTimer"},"parameters":["","\"Timer\""]}],"events":[{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["runtimeScene.setBackgroundColor(100,100,240);","//TODO https://chatgpt.com/c/68629ce3-c954-800b-a3ef-c8215bf9069c","const net = require(\"net\");",""," const client = new net.Socket();","","    client.connect(9898, \"26.0.14.224\", (cli) => {","      // console.log(\"Connected to server\");","      // client.write(`Connected from client ${client.address().address}`);","    });","","    window.tcp = client;"],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":false}]},{"type":"BuiltinCommonInstructions::Link","include":{"includeConfig":0},"target":"Player Movement"},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["Player_Number","=","1"]}],"actions":[{"type":{"value":"SetNumberVariable"},"parameters":["Player_No1.Position_X","=","Player_1.X()"]},{"type":{"value":"SetNumberVariable"},"parameters":["Player_No1.Position_Y","=","Player_1.Y()"]}]},{"disabled":true,"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["Player_Number","=","2"]}],"actions":[{"type":{"value":"SetNumberVariable"},"parameters":["Player_No2.Position_X","=","Player_2.X()"]},{"type":{"value":"SetNumberVariable"},"parameters":["Player_No2.Position_Y","=","Player_2.Y()"]}]},{"disabled":true,"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"NumberVariable"},"parameters":["Player_Number","=","3"]}],"actions":[{"type":{"value":"SetNumberVariable"},"parameters":["Player_No3.Position_X","=","Player_3.X()"]},{"type":{"value":"SetNumberVariable"},"parameters":["Player_No3.Position_Y","=","Player_3.Y()"]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"TextContainerCapability::TextContainerBehavior::SetValue"},"parameters":["Txt_Cout","Text","=","FileSystem::ExecutableFolderPath()"]}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"CompareTimer"},"parameters":["","\"Timer\"",">=","0.05"]}],"actions":[{"type":{"value":"ResetTimer"},"parameters":["","\"Timer\""]}]},{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["runtimeScene.setBackgroundColor(255, 0, 0);","///------------------------------------- MODEL ---------------------------------------------","// TODO ADD FACING DIRECTION","class Player {","  constructor({ number }) {","    this.playerNumber = number;","    this.playerProps = runtimeScene.getGame().getVariables().get(`Player_No${this.playerNumber}`);","    this.posX = this.playerProps.getChild(\"Position_X\").getAsNumber();","    this.posY = this.playerProps.getChild(\"Position_Y\").getAsNumber();","  }","  getPlayer = () => this.playerProps;","  setPosX = (value) => this.playerProps.getChild(\"Position_X\").setNumber(value);","  setPosY = (value) => this.playerProps.getChild(\"Position_Y\").setNumber(value);","","  toJSON() {","    return JSON.stringify({","      Player: this.playerNumber,","      Position: {","        x: this.posX,","        y: this.posY,","      },","    });","  }","}","","///------------------------------------- MODEL ---------------------------------------------","function isJSON(str) {","  try {","    JSON.parse(str);","  } catch (e) {","    return false;","  }","  return true;","}","","const game = runtimeScene.getGame();","const player = game.getVariables().get(\"Player_Number\").getAsNumber;","const player1 = new Player({ number: 1 });","const player2 = new Player({ number: 2 });","const player3 = new Player({ number: 3 });","","window.tcp.on(\"data\", (data) => {","  const dataFromServer = data.toString();","  var splitData = dataFromServer.split('\\n')[0];","  if (isJSON(splitData)) {","    var jsonData = JSON.parse(splitData);","    const playerInData = jsonData[\"Player\"];","    const playerPosInData = jsonData[\"Position\"];","        // player2.setPosX(playerPosInData[\"x\"]);","","    switch (jsonData[\"Player\"]) {","      case 1:","        player1.setPosX(playerPosInData[\"x\"]);","        player1.setPosY(playerPosInData[\"y\"]);","","        break;","      case 2:","        player2.setPosX(playerPosInData[\"x\"]);","        player2.setPosY(playerPosInData[\"y\"]);","","        break;","      case 3:","        player3.setPosX(playerPosInData[\"x\"]);","        player3.setPosY(playerPosInData[\"y\"]);","","        break;","      default:","      console.log('ddd')","    }"," ","  }","});","","window.tcp.on(\"end\", () => {","  console.log(\"Disconnected from server\");","});","","window.tcp.on(\"error\", (err) => {","  console.error(\"Client error:\", err);","});","if(player == 1) window.tcp.write(player1.toJSON() + \"\\n\");","if(player == 2) window.tcp.write(player2.toJSON() + \"\\n\");","if(player == 3) window.tcp.write(player3.toJSON() + \"\\n\");",""],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":true},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[]}],"layers":[{"ambientLightColorB":200,"ambientLightColorG":200,"ambientLightColorR":200,"camera3DFarPlaneDistance":10000.0,"camera3DFieldOfView":45.0,"camera3DNearPlaneDistance":3.0,"cameraType":"","followBaseLayerCamera":false,"isLightingLayer":false,"isLocked":false,"name":"","renderingType":"","visibility":true,"cameras":[{"defaultSize":true,"defaultViewport":true,"height":0.0,"viewportBottom":1.0,"viewportLeft":0.0,"viewportRight":1.0,"viewportTop":0.0,"width":0.0}],"effects":[{"effectType":"Scene3D::HemisphereLight","name":"3D Light","doubleParameters":{"elevation":45.0,"intensity":1.0,"rotation":0.0},"stringParameters":{"groundColor":"64;64;64","skyColor":"255;255;255","top":"Y-"},"booleanParameters":{}}]}],"behaviorsSharedData":[{"name":"Animation","type":"AnimatableCapability::AnimatableBehavior"},{"name":"ButtonFSM","type":"ButtonStates::ButtonFSM"},{"name":"Effect","type":"EffectCapability::EffectBehavior